{
  "source": "superhuman-inbox",
  "entities": [
    {
      "name": "Conversation",
      "fields": [
        "subject",
        "participants",
        "lastMessageAt",
        "status",
        "category",
        "isRead",
        "snoozedUntil"
      ],
      "statusValues": [
        "inbox",
        "done",
        "snoozed",
        "sent",
        "draft"
      ]
    },
    {
      "name": "Message",
      "fields": [
        "sender",
        "recipients",
        "subject",
        "body",
        "sentAt",
        "isRead"
      ],
      "foreignKey": "conversationId→Conversation"
    },
    {
      "name": "Draft",
      "fields": [
        "to",
        "cc",
        "subject",
        "body",
        "updatedAt"
      ],
      "foreignKey": "conversationId→Conversation"
    },
    {
      "name": "Folder",
      "fields": [
        "name",
        "kind",
        "filterRule"
      ],
      "statusValues": [
        "inbox",
        "done",
        "snoozed",
        "sent",
        "drafts",
        "split"
      ]
    },
    {
      "name": "SplitInbox",
      "fields": [
        "name",
        "senderCategory",
        "order"
      ],
      "foreignKey": "folderId→Folder"
    },
    {
      "name": "Snippet",
      "fields": [
        "trigger",
        "body"
      ]
    },
    {
      "name": "UndoableAction",
      "fields": [
        "actionType",
        "targetId",
        "performedAt",
        "expiresAt"
      ]
    }
  ],
  "intents": [
