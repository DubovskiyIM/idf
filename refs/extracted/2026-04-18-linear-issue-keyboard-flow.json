    {
      "name": "Issue",
      "fields": [
        "title",
        "description",
        "status",
        "priority",
        "assignee",
        "labels",
        "estimate",
        "dueDate",
        "cycle",
        "project",
        "parent",
        "createdAt",
        "updatedAt"
