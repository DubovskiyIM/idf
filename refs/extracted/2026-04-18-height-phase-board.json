{
  "source": "height-kanban-board",
  "entities": [
    {
      "name": "Task",
      "fields": [
        "title",
        "status",
        "assignees",
        "labels",
        "dueDate",
        "progress",
        "timeInPhase",
        "projectId"
      ],
      "statusValues": [
        "backlog",
        "up_next",
        "in_progress",
        "blocked",
        "in_review",
        "done"
      ],
      "foreignKey": "projectId→Project"
    },
    {
      "name": "SubTask",
      "fields": [
        "title",
        "status",
        "parentId",
        "assignee"
      ],
      "foreignKey": "parentId→Task",
