      "target": "feed.query",
      "confirmation": "enter"
    },
    {
      "id": "toggle_filter_chip",
      "α": "replace",
      "target": "feed.filters",
      "confirmation": "click"
    },
    {
      "id": "apply_easy",
      "α": "add",
      "creates": "Application",
      "confirmation": "form"
    },
    {
      "id": "apply_external",
      "α": "add",
      "creates": "Application",
      "confirmation": "click"
    },
    {
      "id": "save_job",
      "α": "add",
      "creates": "SavedJob",
      "confirmation": "click"
    },
    {
      "id": "unsave_job",
      "α": "remove",
      "target": "savedJobs",
      "confirmation": "click"
    },
    {
      "id": "save_search",
      "α": "add",
      "creates": "SavedSearch",
      "confirmation": "click"
    },
    {
      "id": "enable_search_alert",
      "α": "replace",
