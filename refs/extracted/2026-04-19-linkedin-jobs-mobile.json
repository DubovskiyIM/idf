      "confirmation": "click"
    },
    {
      "id": "follow_company",
      "α": "add",
      "creates": "CompanyFollow",
      "confirmation": "click"
    },
    {
      "id": "share_job",
      "α": "add",
      "creates": "ShareEvent",
      "confirmation": "click"
    },
    {
      "id": "report_job",
      "α": "add",
      "creates": "Report",
