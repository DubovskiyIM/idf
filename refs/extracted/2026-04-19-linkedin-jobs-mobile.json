{
  "source": "linkedin-jobs-mobile",
  "entities": [
    {
      "name": "JobPosting",
      "fields": [
        "title",
        "company",
        "location",
        "workMode",
        "salaryMin",
        "salaryMax",
        "description",
        "postedAt",
        "easyApplyEnabled",
        "promoted",
        "activelyRecruiting",
        "requiredSkills",
        "recruiterId"
      ],
      "statusValues": [
        "active",
        "closed",
        "filled"
      ]
    },
    {
      "name": "Company",
      "fields": [
        "name",
        "logo",
        "industry",
        "size",
        "about",
        "employeesCount",
        "followerCount"
      ]
    },
    {
      "name": "UserProfile",
      "fields": [
        "photo",
        "fullName",
        "headline",
        "currentCompany",
        "about",
        "experience",
        "education",
        "skills",
        "recommendations",
        "completenessPercent",
        "premiumTier"
      ]
    },
    {
      "name": "Application",
      "fields": [
        "jobId",
        "userId",
        "resumeFile",
        "contactInfo",
        "customAnswers",
        "submittedAt",
        "status"
      ],
      "foreignKey": "jobId→JobPosting",
      "statusValues": [
        "draft",
        "submitted",
        "viewed",
        "interview",
        "rejected",
        "offer"
      ]
    },
    {
      "name": "SavedJob",
      "fields": [
        "jobId",
        "userId",
        "savedAt"
      ],
      "foreignKey": "jobId→JobPosting"
    },
    {
      "name": "SavedSearch",
      "fields": [
        "query",
        "filters",
        "notifyEnabled",
        "createdAt",
        "userId"
      ]
    },
    {
      "name": "SkillMatch",
      "fields": [
        "jobId",
        "userId",
        "matchedSkills",
        "requiredSkills",
        "matchPercent"
      ],
      "foreignKey": "jobId→JobPosting"
    },
    {
      "name": "SocialProof",
      "fields": [
        "jobId",
        "connectionsCount",
        "recruiterName",
        "recruiterPhoto",
        "topApplicantFlag"
      ],
