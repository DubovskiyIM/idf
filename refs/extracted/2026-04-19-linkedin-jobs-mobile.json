    },
    {
      "name": "CompanyFollow",
      "fields": [
        "companyId",
        "userId",
        "followedAt"
      ],
      "foreignKey": "companyId→Company"
    },
    {
      "name": "Endorsement",
      "fields": [
        "skillName",
        "endorserId",
        "profileId",
        "createdAt"
      ],
      "foreignKey": "profileId→UserProfile"
    }
  ],
  "intents": [
