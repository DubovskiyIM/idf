{
  "id": "permission-inheritance-with-override",
  "version": 1,
  "status": "candidate",
  "archetype": "detail",
  "trigger": {
    "requires": [
      {
        "kind": "entity-field",
        "entity": "Permission",
        "field": "inheritedFrom"
      },
      {
        "kind": "entity-field",
        "entity": "Page",
        "field": "parentId",
        "selfRef": true
      },
      {
        "kind": "intent-effect",
        "intent": "change_permission_level",
        "α": "replace",
        "target": "level"
      }
    ]
  },
  "structure": {
    "slot": "sections",
    "description": "Permission section показывает inherited principal'ов греy/lock-icon с tooltip 'Inherited from {parent}'; click 'Override' клонирует запись в текущий уровень и делает её editable."
  },
  "rationale": {
    "hypothesis": "Hierarchy с RBAC требует и default-через-родителя (admin scaling), и точечного override (sensitive sub-page). Visual distinction между inherited vs explicit предотвращает случайное лишение доступа всему поддереву.",
    "evidence": [
      {
        "source": "notion",
        "description": "Page.permissions показывает inherited из parent → teamspace → workspace",
        "reliability": "high"
      },
      {
        "source": "google-drive",
        "description": "Folder permission inheritance с explicit override per file",
        "reliability": "high"
      },
      {
        "source": "confluence",
        "description": "Space → Page → Restricted permissions cascade",
        "reliability": "high"
      },
      {
        "source": "github",
        "description": "Repo → Branch protection с inherit/override",
        "reliability": "medium"
      }
    ],
    "counterexample": [
      {
        "source": "linear",
        "description": "Workspace-flat permissions, без hierarchy и cascade",
        "reliability": "medium"
      }
    ]
  },
  "falsification": {
    "shouldMatch": [
      {
        "domain": "notion",
        "projection": "page_detail",
        "reason": "Permission.inheritedFrom + Page.parentId self-ref + change_permission_level"
      }
    ],
    "shouldNotMatch": [
      {
        "domain": "sales",
        "projection": "listing_detail",
        "reason": "Нет permission-cascade hierarchy между listing'ами"
      }
    ]
  }
}