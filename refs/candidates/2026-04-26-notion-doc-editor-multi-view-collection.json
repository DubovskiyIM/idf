{
  "id": "multi-view-collection",
  "version": 1,
  "status": "candidate",
  "archetype": "catalog",
  "trigger": {
    "requires": [
      {
        "kind": "sub-entity-exists",
        "child": "View",
        "parent": "Database"
      },
      {
        "kind": "entity-field",
        "entity": "View",
        "field": "kind"
      },
      {
        "kind": "intent-creates",
        "creates": "View"
      },
      {
        "kind": "intent-effect",
        "intent": "change_view_kind",
        "α": "replace",
        "target": "kind"
      }
    ]
  },
  "structure": {
    "slot": "header",
    "description": "Header collection-projection'а получает tab-bar из user-defined View'ов, каждый со своим filter/sort/groupBy/visibleProperties; '+' добавляет новый view, click меняет активный."
  },
  "rationale": {
    "hypothesis": "Один dataset обслуживает разные jobs-to-be-done (overview vs progress-tracking vs scheduling); fixed view forces переключения между projections; user-saved views держат каждый job в своём kanban/calendar/table-режиме.",
    "evidence": [
      {
        "source": "notion",
        "description": "6 view-kind'ов на одном Database, tab-bar в header",
        "reliability": "high"
      },
      {
        "source": "linear",
        "description": "Custom views с filter+layout per view",
        "reliability": "high"
      },
      {
        "source": "airtable",
        "description": "Grid/Calendar/Kanban/Gallery views на одной table",
        "reliability": "high"
      },
      {
        "source": "height",
        "description": "List/Board/Calendar views per project",
        "reliability": "medium"
      }
    ],
    "counterexample": [
      {
        "source": "trello",
        "description": "Один board = одна view; поменять layout нельзя без plugin",
        "reliability": "medium"
      }
    ]
  },
  "falsification": {
    "shouldMatch": [
      {
        "domain": "notion",
        "projection": "database_detail",
        "reason": "View sub-entity + 6 kind'ов + create_view + change_view_kind"
      }
    ],
    "shouldNotMatch": [
      {
        "domain": "messenger",
        "projection": "conversations_catalog",
        "reason": "Нет View entity, layout фиксирован"
      }
    ]
  }
}