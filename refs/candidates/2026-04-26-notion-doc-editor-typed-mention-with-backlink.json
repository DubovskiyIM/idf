      },
      {
        "source": "Roam",
        "description": "[[bidirectional links]] с automatic backref на target",
        "reliability": "high"
      },
      {
        "source": "Obsidian",
        "description": "[[ + alias]], graph-view backlinks",
        "reliability": "high"
      }
    ],
    "counterexample": [
      {
        "source": "Slack mentions",
        "description": "@user без backref-rail на user-profile — flat",
        "reliability": "medium"
      }
    ]
