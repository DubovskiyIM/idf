{
  "id": "soft-delete-with-grace-window",
  "version": 1,
  "status": "candidate",
  "archetype": "catalog",
  "trigger": {
    "requires": [
      {
        "kind": "entity-field",
        "field": "archived"
      },
      {
        "kind": "entity-field",
        "field": "archivedAt"
      },
      {
        "kind": "intent-effect",
        "α": "remove",
        "soft": true
      },
      {
        "kind": "intent-effect",
        "α": "remove",
        "irreversibility": "high"
      }
    ]
  },
  "structure": {
    "slot": "sections",
    "description": "Archive-action soft-delete'ит (replace archived=true) с grace-counter в archived-rail; restore — non-destructive; permanent_delete (durable) живёт только в archived-view, irreversible-confirm + reason."
  },
  "rationale": {
    "hypothesis": "Прямой destructive delete как primary-action нарушает 'одна ошибка — потеря данных'; two-stage flow (archive→permanent) даёт reversible default + explicit irreversible action для recovery scenarios.",
    "evidence": [
      {
        "source": "Notion",
        "description": "Archive с 30-day Trash, permanent delete только из Trash",
        "reliability": "high"
      },
      {
        "source": "Gmail",
        "description": "Trash 30d retention + permanent only там",
        "reliability": "high"
      },
      {
        "source": "Linear",
        "description": "Cancel issue + Hard delete двухступенчато",
        "reliability": "high"
      }
    ],
    "counterexample": [
      {
        "source": "Ephemeral data",
        "description": "Draft чат-сообщение — direct delete достаточно",
        "reliability": "high"
      }
    ]
  },
  "falsification": {
    "shouldMatch": [
      {
        "domain": "notion",
        "projection": "trash",
        "reason": "Page.archived + archive_page + delete_page_permanent"
      }
    ],
    "shouldNotMatch": [
      {
        "domain": "messenger",
        "projection": "messages",
        "reason": "Message direct delete, нет grace"
      }
    ]
  }
}