{
  "id": "scoped-template-library",
  "version": 1,
  "status": "candidate",
  "archetype": "catalog",
  "trigger": {
    "requires": [
      {
        "kind": "entity-field",
        "field": "scope",
        "discriminator": true,
        "values-include": [
          "workspace",
          "user"
        ]
      },
      {
        "kind": "intent-creates",
        "creates": "Template"
      },
      {
        "kind": "intent-effect",
        "intent": "apply_template",
        "α": "add"
      }
    ]
  },
  "structure": {
    "slot": "sections",
    "description": "Template-catalog разделён на shared (workspace-scope) и mine (user-scope) tabs; apply_template копирует root structure в новую entity, не keeps reference. Visibility scope — first-class, не permission-derived."
  },
  "rationale": {
    "hypothesis": "Templates с глобальным single-namespace создают дилемму: либо публикуй незрелое (засоряет всем), либо не публикуй (не share-аешь). Two-scope разделяет 'private staging' от 'team standard', снимает блок к прототипированию.",
    "evidence": [
      {
        "source": "notion",
        "description": "Templates → Workspace + My templates tabs",
        "reliability": "high"
      },
      {
        "source": "linear",
        "description": "Issue templates на team-level + project-level",
        "reliability": "high"
      },
      {
        "source": "figma",
        "description": "Personal vs team library publish",
        "reliability": "high"
      }
    ],
    "counterexample": [
      {
        "source": "vscode-snippets",
        "description": "User vs project scope — то же разделение в dev-tools",
        "reliability": "medium"
      }
    ]
  },
  "falsification": {
    "shouldMatch": [
      {
        "domain": "notion",
        "projection": "templates_catalog",
        "reason": "Template.scope ∈ {workspace,user}"
      }
    ],
    "shouldNotMatch": [
      {
        "domain": "delivery",
        "projection": "menu_items",
        "reason": "MenuItem — single-scope, нет user-private"
      }
    ]
  }
}