{
  "id": "publish-with-subtree-checklist",
  "version": 1,
  "status": "candidate",
  "archetype": "detail",
  "trigger": {
    "requires": [
      {
        "kind": "intent-creates",
        "entity": "<published-entity>"
      },
      {
        "kind": "entity-field",
        "entity": "<published-entity>",
        "field": "includesSubtree"
      },
      {
        "kind": "entity-kind",
        "value": "self-referential"
      }
    ]
  },
  "structure": {
    "slot": "primaryCTA",
    "description": "Publish-form для self-ref entity рендерит tree-checklist дочерних узлов с per-node toggle 'expose' (default — все); включает SEO/indexable flags; explicit включение subtree предотвращает accidental private-leak."
  },
  "rationale": {
    "hypothesis": "Когда entity self-ref и публикуется, неконтролируемая subtree-publish протекает private-pages в public site; explicit checkbox-tree даёт автору per-node контроль и делает 'что именно публикуется' видимым.",
    "evidence": [
      {
        "source": "Notion",
        "description": "Publish toggle + 'Show subpages' checkbox + indexable",
        "reliability": "high"
      },
      {
        "source": "Confluence",
        "description": "Space-publish с per-page exclude",
        "reliability": "medium"
      }
    ],
    "counterexample": [
      {
        "source": "Single-page publish",
        "description": "Без иерархии checklist излишен",
        "reliability": "high"
      }
    ]
  },
  "falsification": {
    "shouldMatch": [
      {
        "domain": "notion",
        "projection": "page_publish",
        "reason": "PublishedPage.includesSubtree + Page self-ref"
      }
    ],
    "shouldNotMatch": [
      {
        "domain": "sales",
        "projection": "listing_publish",
        "reason": "Listing не self-ref, нет subtree-publish"
      }
    ]
  }
}