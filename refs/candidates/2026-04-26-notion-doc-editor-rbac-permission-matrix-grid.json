{
  "id": "rbac-permission-matrix-grid",
  "version": 1,
  "status": "candidate",
  "archetype": "detail",
  "trigger": {
    "requires": [
      {
        "kind": "has-role",
        "min": 3
      },
      {
        "kind": "intent-effect",
        "α": "replace",
        "targetField": "role"
      },
      {
        "kind": "entity-kind",
        "value": "membership"
      }
    ]
  },
  "structure": {
    "slot": "body",
    "description": "Workspace-settings рендерит role × capability grid: строки=roles, колонки=actions, ячейки=✓/✗; редактирование — toggle ячейки или change_member_role в member-list."
  },
  "rationale": {
    "hypothesis": "Когда ≥3 ролей и десятки intent'ов, list-of-roles-with-text-description нечитаем; explicit matrix делает capability-сравнение между ролями glance-able и подсвечивает gaps.",
    "evidence": [
      {
        "source": "Notion",
        "description": "Settings → Members → role-permission table",
        "reliability": "high"
      },
      {
        "source": "GitHub orgs",
        "description": "Role × repo-action grid",
        "reliability": "high"
      },
      {
        "source": "Linear",
        "description": "Member-roles + capability matrix",
        "reliability": "medium"
      }
    ],
    "counterexample": [
      {
        "source": "Domain c 2 ролями",
        "description": "Owner/viewer — flat enough, matrix overhead",
        "reliability": "high"
      }
    ]
  },
  "falsification": {
    "shouldMatch": [
      {
        "domain": "notion",
        "projection": "workspace_settings",
        "reason": "5 ролей × 40+ intents"
      }
    ],
    "shouldNotMatch": [
      {
        "domain": "lifequest",
        "projection": "goals",
        "reason": "Single-user домен без roles"
      },
      {
        "domain": "planning",
        "projection": "polls",
        "reason": "Только organizer/participant — flat"
      }
    ]
  }
}