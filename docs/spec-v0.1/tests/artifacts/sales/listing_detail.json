          "type": "text",
          "bind": "listingId",
          "style": {
            "fontWeight": 600,
            "fontSize": 14
          }
        },
        "itemIntents": [
          {
            "intentId": "place_bid",
            "label": "Сделать ставку",
            "icon": "⚡",
            "conditions": [
              "listing.status = 'active'"
            ],
            "createsDiscriminator": null
          },
          {
            "intentId": "retract_bid",
            "label": "Отозвать ставку",
            "icon": "⚡",
            "conditions": [
              "bid.status = 'active'",
              "bid.bidderId = me.id"
            ],
            "createsDiscriminator": null
          },
          {
            "intentId": "increase_bid",
            "label": "Повысить ставку",
            "icon": "⚡",
            "conditions": [
              "bid.bidderId = me.id",
              "listing.status = 'active'"
            ],
            "createsDiscriminator": null
          },
          {
            "intentId": "accept_bid",
            "label": "Принять ставку досрочно",
            "icon": "✓",
            "conditions": [
              "listing.status = 'active'",
              "listing.sellerId = me.id",
              "bid.status = 'active'"
            ],
            "createsDiscriminator": "Order(pending_payment)",
            "discriminator": "pending_payment"
          }
        ],
        "addControl": {
          "type": "subCollectionAdd",
          "intentId": "set_auto_bid",
          "label": "Автоставка",
          "icon": "⚡",
          "parameters": [
            {
              "name": "maxAmount",
              "inferredFrom": "direct-witness",
              "control": "number"
            }
          ],
          "foreignKey": "listingId",
          "conditions": [
            "listing.status = 'active'"
          ]
        },
        "emptyLabel": "Пока пусто"
      }
    ],
    "primaryCTA": [
      {
        "intentId": "publish_listing",
        "label": "Опубликовать",
        "icon": "⚡",
        "conditions": [
          "listing.status = 'draft'",
          "listing.sellerId = me.id"
        ],
        "parameters": []
      },
