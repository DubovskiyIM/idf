{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "domain.schema.json",
  "title": "IDF Domain",
  "description": "Complete domain definition: intents, ontology, and optional projections and invariants.",
  "type": "object",
  "required": ["intents", "ontology"],
  "properties": {
    "intents": {
      "type": "object",
      "description": "Map of intent ids to intent definitions.",
      "additionalProperties": {
        "$ref": "intent.schema.json"
      }
    },
    "ontology": {
      "$ref": "ontology.schema.json"
    },
    "projections": {
      "type": "object",
      "description": "Map of projection ids to projection definitions.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "invariants": {
      "type": "array",
      "description": "Domain invariants (integrity rules).",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
