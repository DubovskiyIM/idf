{
  "id": "level-2/seq-001",
  "level": 2,
  "name": "replace effect → sequential link to matching condition",
  "description": "Intent publish_task has effect replace task.status→active. Intent close_task has condition task.status='active'. This creates a sequential ▷ link from publish_task to close_task.",
  "input": {
    "intents": {
      "publish_task": {
        "name": "Publish task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": ["task.status = 'draft'"],
          "effects": [{"α": "replace", "target": "task.status", "value": "active"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      },
      "close_task": {
        "name": "Close task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": ["task.status = 'active'"],
          "effects": [{"α": "replace", "target": "task.status", "value": "done"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      }
    },
    "ontology": {
      "entities": {
        "Task": {
          "fields": {
            "id": {"type": "string"},
            "title": {"type": "string"},
            "status": {"type": "string", "enum": ["draft", "active", "done"]}
          }
        }
      }
    }
  },
  "expected": {
    "relations": {
      "publish_task": {
        "sequentialOut": ["close_task"]
      },
      "close_task": {
        "sequentialIn": ["publish_task"]
      }
    }
  }
}
