{
  "id": "level-2/seq-003",
  "level": 2,
  "name": "chain of 3: create → publish → close (transitive ▷)",
  "description": "Three intents form a sequential chain: create_task(draft) ▷ publish_task(draft→active) ▷ close_task(active→done). Each link is derived independently from effect-condition matching.",
  "input": {
    "intents": {
      "create_task": {
        "name": "Create task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": [],
          "effects": [{"α": "add", "target": "tasks"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": "Task(draft)",
        "antagonist": null
      },
      "publish_task": {
        "name": "Publish task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": ["task.status = 'draft'"],
          "effects": [{"α": "replace", "target": "task.status", "value": "active"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      },
      "close_task": {
        "name": "Close task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": ["task.status = 'active'"],
          "effects": [{"α": "replace", "target": "task.status", "value": "done"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      }
    },
    "ontology": {
      "entities": {
        "Task": {
          "fields": {
            "id": {"type": "string"},
            "title": {"type": "string"},
            "status": {"type": "string", "enum": ["draft", "active", "done"]}
          }
        }
      }
    }
  },
  "expected": {
    "relations": {
      "create_task": {
        "sequentialOut": ["publish_task"]
      },
      "publish_task": {
        "sequentialIn": ["create_task"],
        "sequentialOut": ["close_task"]
      },
      "close_task": {
        "sequentialIn": ["publish_task"]
      }
    }
  }
}
