{
  "id": "level-2/excl-001",
  "level": 2,
  "name": "replace + add on same entity → ⊕ excluding",
  "description": "Intent publish_task has replace effect on task.status. Intent create_task has add effect on tasks. Per the composition table, replace + add on the same target is ⊥ (conflict), yielding an excluding ⊕ relation.",
  "input": {
    "intents": {
      "publish_task": {
        "name": "Publish task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": ["task.status = 'draft'"],
          "effects": [{"α": "replace", "target": "tasks.status", "value": "active"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      },
      "add_task_tag": {
        "name": "Add task tag",
        "particles": {
          "entities": ["t: Task"],
          "conditions": [],
          "effects": [{"α": "add", "target": "tasks.status"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      }
    },
    "ontology": {
      "entities": {
        "Task": {
          "fields": {
            "id": {"type": "string"},
            "title": {"type": "string"},
            "status": {"type": "string", "enum": ["draft", "active", "done"]}
          }
        }
      }
    }
  },
  "expected": {
    "relations": {
      "publish_task": {
        "excluding": ["add_task_tag"]
      },
      "add_task_tag": {
        "excluding": ["publish_task"]
      }
    }
  }
}
