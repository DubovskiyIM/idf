{
  "id": "level-2/seq-004",
  "level": 2,
  "name": "no sequential link when effect doesn't match any condition",
  "description": "Intent publish_task sets status→active, but rename_task has no conditions at all. No sequential link should exist between them.",
  "input": {
    "intents": {
      "publish_task": {
        "name": "Publish task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": ["task.status = 'draft'"],
          "effects": [{"α": "replace", "target": "task.status", "value": "active"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      },
      "rename_task": {
        "name": "Rename task",
        "particles": {
          "entities": ["t: Task"],
          "conditions": [],
          "effects": [{"α": "replace", "target": "task.title", "value": "{{newTitle}}"}],
          "witnesses": ["title"],
          "confirmation": "click"
        },
        "creates": null,
        "antagonist": null
      }
    },
    "ontology": {
      "entities": {
        "Task": {
          "fields": {
            "id": {"type": "string"},
            "title": {"type": "string"},
            "status": {"type": "string", "enum": ["draft", "active", "done"]}
          }
        }
      }
    }
  },
  "expected": {
    "relations": {
      "publish_task": {
        "sequentialOut": []
      },
      "rename_task": {
        "sequentialIn": []
      }
    }
  }
}
