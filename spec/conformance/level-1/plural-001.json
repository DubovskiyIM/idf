{
  "id": "level-1/plural-001",
  "level": 1,
  "name": "entity name pluralization rules",
  "description": "Entity names should be pluralized correctly when used as collection keys in the world: User -> users, Category -> categories, Listing -> listings, Address -> addresses.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "target": "categories",
        "scope": "account",
        "status": "confirmed",
        "created_at": 2000,
        "alpha": "add",
        "context": {
          "id": "c1",
          "name": "Electronics"
        }
      },
      {
        "id": "e3",
        "intent_id": "e3",
        "target": "listings",
        "scope": "account",
        "status": "confirmed",
        "created_at": 3000,
        "alpha": "add",
        "context": {
          "id": "l1",
          "title": "Phone"
        }
      },
      {
        "id": "e4",
        "intent_id": "e4",
        "target": "addresses",
        "scope": "account",
        "status": "confirmed",
        "created_at": 4000,
        "alpha": "add",
        "context": {
          "id": "a1",
          "city": "Moscow"
        }
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        },
        "Category": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        },
        "Listing": {
          "fields": {
            "title": {
              "type": "string"
            }
          }
        },
        "Address": {
          "fields": {
            "city": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Alice"
        }
      ],
      "categories": [
        {
          "id": "c1",
          "name": "Electronics"
        }
      ],
      "listings": [
        {
          "id": "l1",
          "title": "Phone"
        }
      ],
      "addresses": [
        {
          "id": "a1",
          "city": "Moscow"
        }
      ]
    }
  }
}
