          "id": "l1",
          "title": "Item",
          "status": "draft"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "alpha": "replace",
        "target": "listing.status",
        "context": {
          "id": "l1"
        },
        "value": "active",
        "scope": "account",
        "status": "confirmed",
        "created_at": 3000
      }
    ],
    "ontology": {
      "entities": {
        "Listing": {
          "fields": {
            "title": {
              "type": "string"
            },
            "status": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
