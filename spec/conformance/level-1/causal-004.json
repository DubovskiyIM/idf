{
  "id": "level-1/causal-004",
  "level": 1,
  "name": "two independent roots both applied in created_at order",
  "description": "Two root effects (no parent_id) targeting different entities should both be applied, ordered by created_at.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "type": "add",
        "target": "User",
        "payload": { "id": "u1", "name": "Alice" },
        "status": "confirmed",
        "created_at": 1000,
        "parent_id": null
      },
      {
        "id": "e2",
        "type": "add",
        "target": "User",
        "payload": { "id": "u2", "name": "Bob" },
        "status": "confirmed",
        "created_at": 2000,
        "parent_id": null
      }
    ],
    "ontology": {
      "entities": {
        "User": { "fields": { "name": { "type": "string" } } }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        { "id": "u1", "name": "Alice" },
        { "id": "u2", "name": "Bob" }
      ]
    }
  }
}
