{
  "id": "level-1/causal-004",
  "level": 1,
  "name": "two independent roots both applied in created_at order",
  "description": "Two root effects (no parent_id) targeting different entities should both be applied, ordered by created_at.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 2000,
        "alpha": "add",
        "context": {
          "id": "u2",
          "name": "Bob"
        }
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Alice"
        },
        {
          "id": "u2",
          "name": "Bob"
        }
      ]
    }
  }
}
