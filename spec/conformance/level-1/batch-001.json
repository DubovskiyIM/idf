{
  "id": "level-1/batch-001",
  "level": 1,
  "name": "batch with two sub-effects applied atomically",
  "description": "A batch effect containing an add and a replace sub-effect should apply both. The add creates the entity, the replace updates it.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "type": "batch",
        "target": "User",
        "payload": {
          "effects": [
            {
              "id": "e1a",
              "type": "add",
              "target": "User",
              "payload": { "id": "u1", "name": "Alice", "role": "buyer" },
              "status": "confirmed",
              "created_at": 1000
            },
            {
              "id": "e1b",
              "type": "replace",
              "target": "User",
              "payload": { "id": "u1", "role": "seller" },
              "status": "confirmed",
              "created_at": 1001
            }
          ]
        },
        "status": "confirmed",
        "created_at": 1000
      }
    ],
    "ontology": {
      "entities": {
        "User": { "fields": { "name": { "type": "string" }, "role": { "type": "string" } } }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        { "id": "u1", "name": "Alice", "role": "seller" }
      ]
    }
  }
}
