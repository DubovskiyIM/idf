{
  "id": "level-1/batch-001",
  "level": 1,
  "name": "batch with two sub-effects applied atomically",
  "description": "A batch effect containing an add and a replace sub-effect should apply both. The add creates the entity, the replace updates it.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "batch",
        "value": [
          {
            "id": "e1a",
            "intent_id": "e1a",
            "target": "users",
            "scope": "account",
            "status": "confirmed",
            "created_at": 1000,
            "alpha": "add",
            "context": {
              "id": "u1",
              "name": "Alice",
              "role": "buyer"
            }
          },
          {
            "id": "e1b",
            "intent_id": "e1b",
            "alpha": "replace",
            "target": "user.role",
            "context": {
              "id": "u1"
            },
            "value": "seller",
            "scope": "account",
            "status": "confirmed",
            "created_at": 1001
          }
        ],
        "context": {}
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            },
            "role": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Alice",
          "role": "seller"
        }
      ]
    }
  }
}
