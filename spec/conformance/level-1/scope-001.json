{
  "id": "level-1/scope-001",
  "level": 1,
  "name": "presentation scope excluded from semantic fold",
  "description": "An effect with scope 'presentation' should not be included in the semantic world fold. Only effects without scope (or with scope 'semantic') participate.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "alpha": "replace",
        "target": "user.highlighted",
        "context": {
          "id": "u1"
        },
        "value": true,
        "scope": "presentation",
        "status": "confirmed",
        "created_at": 2000
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            },
            "highlighted": {
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Alice"
        }
      ]
    }
  }
}
