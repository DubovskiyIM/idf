{
  "id": "level-1/batch-003",
  "level": 1,
  "name": "batch with three replaces updates all fields",
  "description": "A batch containing an add followed by three replace effects on the same entity should result in all fields being updated.",
  "input": {
    "effects": [
      {
        "id": "e0",
        "type": "add",
        "target": "Listing",
        "payload": { "id": "l1", "title": "Old", "price": 100, "status": "draft" },
        "status": "confirmed",
        "created_at": 1000
      },
      {
        "id": "e1",
        "type": "batch",
        "target": "Listing",
        "payload": {
          "effects": [
            {
              "id": "e1a",
              "type": "replace",
              "target": "Listing",
              "payload": { "id": "l1", "title": "New Title" },
              "status": "confirmed",
              "created_at": 2000
            },
            {
              "id": "e1b",
              "type": "replace",
              "target": "Listing",
              "payload": { "id": "l1", "price": 250 },
              "status": "confirmed",
              "created_at": 2001
            },
            {
              "id": "e1c",
              "type": "replace",
              "target": "Listing",
              "payload": { "id": "l1", "status": "active" },
              "status": "confirmed",
              "created_at": 2002
            }
          ]
        },
        "status": "confirmed",
        "created_at": 2000
      }
    ],
    "ontology": {
      "entities": {
        "Listing": { "fields": { "title": { "type": "string" }, "price": { "type": "number" }, "status": { "type": "string" } } }
      }
    }
  },
  "expected": {
    "world": {
      "listings": [
        { "id": "l1", "title": "New Title", "price": 250, "status": "active" }
      ]
    }
  }
}
