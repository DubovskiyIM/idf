{
  "id": "level-1/causal-002",
  "level": 1,
  "name": "child with earlier created_at still applied after parent",
  "description": "Even if the child effect has an earlier created_at than its parent, causal sort ensures parent is applied first based on parent_id dependency.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "listings",
        "scope": "account",
        "status": "confirmed",
        "created_at": 3000,
        "alpha": "add",
        "context": {
          "id": "l1",
          "title": "Created",
          "price": 100
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "parent_id": "e1",
        "alpha": "replace",
        "target": "listing.price",
        "context": {
          "id": "l1"
        },
        "value": 999,
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000
      }
    ],
    "ontology": {
      "entities": {
        "Listing": {
          "fields": {
            "title": {
              "type": "string"
            },
            "price": {
              "type": "number"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "listings": [
        {
          "id": "l1",
          "title": "Created",
          "price": 999
        }
      ]
    }
  }
}
