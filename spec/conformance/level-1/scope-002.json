{
  "id": "level-1/scope-002",
  "level": 1,
  "name": "drafts target excluded from semantic fold",
  "description": "An effect targeting the drafts scope (target prefixed with 'drafts:') should not appear in the semantic world fold.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "target": "drafts:user",
        "scope": "account",
        "status": "confirmed",
        "created_at": 2000,
        "alpha": "add",
        "context": {
          "id": "u2",
          "name": "Draft Bob"
        }
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Alice"
        }
      ]
    }
  }
}
