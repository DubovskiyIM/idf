{
  "id": "level-1/fold-002",
  "level": 1,
  "name": "add then replace updates field",
  "description": "An add effect followed by a replace effect on the same entity should produce a world where the entity has the updated field value.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "alpha": "replace",
        "target": "user.name",
        "context": {
          "id": "u1"
        },
        "value": "Bob",
        "scope": "account",
        "status": "confirmed",
        "created_at": 2000
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Bob"
        }
      ]
    }
  }
}
