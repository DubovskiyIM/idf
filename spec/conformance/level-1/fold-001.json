{
  "id": "level-1/fold-001",
  "level": 1,
  "name": "single add effect creates one entity",
  "description": "A single confirmed add effect targeting User collection should produce a world with one user entity containing the specified fields.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        {
          "id": "u1",
          "name": "Alice"
        }
      ]
    }
  }
}
