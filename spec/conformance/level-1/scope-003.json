{
  "id": "level-1/scope-003",
  "level": 1,
  "name": "presentation effect applied via applyPresentation",
  "description": "When presentation effects are applied separately (via applyPresentation), they should update visual fields on entities already in the semantic world.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      }
    ],
    "presentation_effects": [
      {
        "id": "p1",
        "intent_id": "p1",
        "alpha": "replace",
        "target": "user.highlighted",
        "context": {
          "id": "u1"
        },
        "value": true,
        "scope": "presentation",
        "status": "confirmed",
        "created_at": 2000
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            },
            "highlighted": {
              "type": "boolean"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world_after_presentation": {
      "users": [
        {
          "id": "u1",
          "name": "Alice",
          "highlighted": true
        }
      ]
    }
  }
}
