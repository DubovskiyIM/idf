{
  "id": "level-1/fold-003",
  "level": 1,
  "name": "add then remove produces empty collection",
  "description": "An add effect followed by a remove effect on the same entity should result in an empty collection.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "intent_id": "e1",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 1000,
        "alpha": "add",
        "context": {
          "id": "u1",
          "name": "Alice"
        }
      },
      {
        "id": "e2",
        "intent_id": "e2",
        "target": "users",
        "scope": "account",
        "status": "confirmed",
        "created_at": 2000,
        "alpha": "remove",
        "context": {
          "id": "u1"
        }
      }
    ],
    "ontology": {
      "entities": {
        "User": {
          "fields": {
            "name": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "expected": {
    "world": {
      "users": []
    }
  }
}
