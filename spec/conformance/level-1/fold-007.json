{
  "id": "level-1/fold-007",
  "level": 1,
  "name": "multiple collections populated independently",
  "description": "Add effects targeting different collections (User and Listing) should populate both collections independently.",
  "input": {
    "effects": [
      {
        "id": "e1",
        "type": "add",
        "target": "User",
        "payload": { "id": "u1", "name": "Alice" },
        "status": "confirmed",
        "created_at": 1000
      },
      {
        "id": "e2",
        "type": "add",
        "target": "Listing",
        "payload": { "id": "l1", "title": "Vintage Clock", "price": 500 },
        "status": "confirmed",
        "created_at": 2000
      }
    ],
    "ontology": {
      "entities": {
        "User": { "fields": { "name": { "type": "string" } } },
        "Listing": { "fields": { "title": { "type": "string" }, "price": { "type": "number" } } }
      }
    }
  },
  "expected": {
    "world": {
      "users": [
        { "id": "u1", "name": "Alice" }
      ],
      "listings": [
        { "id": "l1", "title": "Vintage Clock", "price": 500 }
      ]
    }
  }
}
