{
  "id": "level-3/antagonist-001",
  "level": 3,
  "name": "declared antagonist with structural backing",
  "description": "Intent declares antagonist and algebra can derive structural evidence (effect pair-reversal: one sets status to X, the other sets it back). Should produce info finding with classification 'structural'.",
  "input": {
    "intents": {
      "create_item": {
        "id": "create_item",
        "name": "Создать товар",
        "creates": "Item",
        "particles": {
          "entities": ["Item"],
          "conditions": [],
          "effects": [{ "type": "add", "target": "items", "payload": { "status": "active" } }],
          "witnesses": []
        }
      },
      "archive_item": {
        "id": "archive_item",
        "name": "Архивировать товар",
        "antagonist": "restore_item",
        "particles": {
          "entities": ["Item"],
          "conditions": ["item.status = 'active'"],
          "effects": [{ "type": "replace", "target": "items.status", "payload": "archived" }],
          "witnesses": ["item.title", "item.status"]
        }
      },
      "restore_item": {
        "id": "restore_item",
        "name": "Восстановить товар",
        "antagonist": "archive_item",
        "particles": {
          "entities": ["Item"],
          "conditions": ["item.status = 'archived'"],
          "effects": [{ "type": "replace", "target": "items.status", "payload": "active" }],
          "witnesses": ["item.title", "item.status"]
        }
      }
    },
    "ontology": {
      "entities": {
        "Item": {
          "fields": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string" },
            "ownerId": { "type": "entityRef", "ref": "User" }
          },
          "ownerField": "ownerId"
        },
        "User": {
          "fields": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      }
    },
    "projections": {
      "item_list": { "kind": "catalog", "entities": ["Item"], "mainEntity": "Item" }
    }
  },
  "expected": {
    "findings": []
  }
}
