            "Item"
          ],
          "conditions": [
            "item.status = 'active'"
          ],
          "effects": [
            {
              "α": "replace",
              "target": "items.status"
            }
          ],
          "witnesses": [
            "item.title",
            "item.status"
          ]
        }
      },
      "restore_item": {
        "id": "restore_item",
        "name": "Восстановить товар",
