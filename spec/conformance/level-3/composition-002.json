            "Item"
          ],
          "conditions": [
            "item.status = 'archived'"
          ],
          "effects": [
            {
              "α": "replace",
              "target": "items.status"
            }
          ],
          "witnesses": [
            "item.title",
            "item.status"
          ]
        }
      },
      "create_item": {
