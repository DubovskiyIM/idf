{
  "id": "level-3/anchor-003",
  "level": 3,
  "name": "all entities and fields exist in ontology",
  "description": "All intent entities, effect targets, and witnesses reference entities and fields that exist in ontology. No anchoring findings expected.",
  "input": {
    "intents": {
      "create_item": {
        "id": "create_item",
        "name": "Создать товар",
        "creates": "Item",
        "particles": {
          "entities": ["Item"],
          "conditions": [],
          "effects": [{ "type": "add", "target": "items", "payload": { "status": "active", "title": "New" } }],
          "witnesses": ["item.title"]
        }
      },
      "edit_title": {
        "id": "edit_title",
        "name": "Изменить название",
        "particles": {
          "entities": ["Item"],
          "conditions": ["item.status = 'active'"],
          "effects": [{ "type": "replace", "target": "items.title" }],
          "witnesses": ["item.title", "item.status"]
        }
      }
    },
    "ontology": {
      "entities": {
        "Item": {
          "fields": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string" },
            "ownerId": { "type": "entityRef", "ref": "User" }
          },
          "ownerField": "ownerId"
        },
        "User": {
          "fields": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      }
    },
    "projections": {
      "item_list": { "kind": "catalog", "entities": ["Item"], "mainEntity": "Item" }
    }
  },
  "expected": {
    "findings": [],
    "blocking": false
  }
}
