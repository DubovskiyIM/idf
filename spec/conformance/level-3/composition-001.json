{
  "id": "level-3/composition-001",
  "level": 3,
  "name": "two intents with excluding conflict and overlapping conditions",
  "description": "Two intents that both target the same field with conflicting effect types (add vs remove on same entity) and have overlapping conditions. Should produce algebra composition warning.",
  "input": {
    "intents": {
      "activate_item": {
        "id": "activate_item",
        "name": "Активировать товар",
        "particles": {
          "entities": ["Item"],
          "conditions": ["item.status = 'draft'"],
          "effects": [{ "type": "replace", "target": "items.status", "payload": "active" }],
          "witnesses": ["item.title", "item.status"]
        }
      },
      "delete_draft_item": {
        "id": "delete_draft_item",
        "name": "Удалить черновик",
        "particles": {
          "entities": ["Item"],
          "conditions": ["item.status = 'draft'"],
          "effects": [{ "type": "remove", "target": "items" }],
          "witnesses": ["item.title", "item.status"]
        }
      },
      "create_item": {
        "id": "create_item",
        "name": "Создать товар",
        "creates": "Item",
        "particles": {
          "entities": ["Item"],
          "conditions": [],
          "effects": [{ "type": "add", "target": "items", "payload": { "status": "draft" } }],
          "witnesses": []
        }
      }
    },
    "ontology": {
      "entities": {
        "Item": {
          "fields": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "status": { "type": "string" },
            "ownerId": { "type": "entityRef", "ref": "User" }
          },
          "ownerField": "ownerId"
        },
        "User": {
          "fields": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        }
      }
    },
    "projections": {
      "item_list": { "kind": "catalog", "entities": ["Item"], "mainEntity": "Item" }
    }
  },
  "expected": {
    "findings": [
      {
        "rule": "algebra_composition",
        "intentId": "activate_item ⊗ delete_draft_item",
        "severity": "error",
        "message": "Excluding conflict between intents with overlapping conditions"
      }
    ]
  }
}
