{
  "name": "idf",
  "version": "1.0.0",
  "description": "Intent-Driven Frontend — исследовательский прототип парадигмы, в которой UI выводится из формального описания пользовательских намерений",
  "author": "Ignat Dubovsky",
  "license": "MIT",
  "keywords": [
    "intent-driven",
    "frontend",
    "manifesto",
    "crystallization",
    "event-sourcing",
    "llm-agent",
    "declarative-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server/index.js",
    "calendar": "node external-calendar/index.js",
    "invest-ml": "node invest-ml/index.js",
    "invest-fuzzy": "node invest-fuzzy/index.js",
    "market-data": "node market-data/index.js",
    "courier-feed": "node courier-location-feed/index.js",
    "geocoder": "node geocoder/index.js",
    "payment-gw": "node payment-gateway/index.js",
    "notify-gw": "node notification-gateway/index.js",
    "delivery-seed": "node scripts/delivery-seed.mjs",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "test:core": "cd packages/core && npx vitest run",
    "agent-smoke": "node scripts/agent-smoke.mjs",
    "crystallize-llm": "node scripts/crystallize-llm.mjs",
    "sales-demo": "node scripts/sales-walkthrough.mjs"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/plots": "^2.6.8",
    "@anthropic-ai/sdk": "^0.88.0",
    "@intent-driven/core": "file:../idf-sdk/packages/core",
    "@intent-driven/renderer": "file:../idf-sdk/packages/renderer",
    "@intent-driven/adapter-mantine": "file:../idf-sdk/packages/adapter-mantine",
    "@intent-driven/adapter-shadcn": "file:../idf-sdk/packages/adapter-shadcn",
    "@intent-driven/adapter-apple": "file:../idf-sdk/packages/adapter-apple",
    "@intent-driven/adapter-antd": "file:../idf-sdk/packages/adapter-antd",
    "@intent-driven/canvas-kit": "file:../idf-sdk/packages/canvas-kit",
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.3.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-3d": "^1.29.1",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "uuid": "^13.0.0",
    "vite": "^8.0.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  },
  "private": true
}
