{
  "name": "idf",
  "version": "1.0.0",
  "description": "Intent-Driven Frontend — исследовательский прототип парадигмы, в которой UI выводится из формального описания пользовательских намерений",
  "author": "Ignat Dubovsky",
  "license": "MIT",
  "keywords": [
    "intent-driven",
    "frontend",
    "manifesto",
    "crystallization",
    "event-sourcing",
    "llm-agent",
    "declarative-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server/index.js",
    "calendar": "node external-calendar/index.js",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "test:core": "cd packages/core && npx vitest run",
    "agent-smoke": "node scripts/agent-smoke.mjs",
    "crystallize-llm": "node scripts/crystallize-llm.mjs",
    "meshok-demo": "node scripts/meshok-walkthrough.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-3d": "^1.29.1",
    "react-router-dom": "^7.14.0",
    "uuid": "^13.0.0",
    "vite": "^8.0.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  },
  "private": true
}
