{
  "name": "idf",
  "version": "1.0.0",
  "description": "Intent-Driven Frontend — исследовательский прототип парадигмы, в которой UI выводится из формального описания пользовательских намерений",
  "author": "Ignat Dubovsky",
  "license": "MIT",
  "keywords": [
    "intent-driven",
    "frontend",
    "manifesto",
    "crystallization",
    "event-sourcing",
    "llm-agent",
    "declarative-ui"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server/index.js",
    "calendar": "node external-calendar/index.js",
    "invest-ml": "node invest-ml/index.js",
    "invest-fuzzy": "node invest-fuzzy/index.js",
    "market-data": "node market-data/index.js",
    "courier-feed": "node courier-location-feed/index.js",
    "geocoder": "node geocoder/index.js",
    "payment-gw": "node payment-gateway/index.js",
    "notify-gw": "node notification-gateway/index.js",
    "delivery-seed": "node scripts/delivery-seed.mjs",
    "meta-snapshot": "node scripts/build-meta-snapshot.mjs",
    "meta-compile": "node scripts/meta-compile.mjs",
    "meta": "node scripts/meta-cli.mjs",
    "meta-mcp": "node scripts/mcp-meta.mjs",
    "test": "vitest run --config vitest.config.js",
    "test:watch": "vitest --config vitest.config.js",
    "conformance": "node scripts/conformance-runner.mjs",
    "test:core": "cd packages/core && npx vitest run",
    "agent-smoke": "node scripts/agent-smoke.mjs",
    "smoke-compliance": "node scripts/smoke-compliance.mjs",
    "smoke-fold-invest": "node scripts/fold-invest-agent-smoke.mjs",
    "audit-domains": "node scripts/domain-audit.mjs --all",
    "audit-report": "node scripts/audit-report.mjs",
    "crystallize-llm": "node scripts/crystallize-llm.mjs",
    "sales-demo": "node scripts/sales-walkthrough.mjs",
    "dev:studio": "concurrently -n server,vite \"npm run server\" \"vite --host 0.0.0.0\"",
    "dev:curator": "CURATOR_PR_ENABLED=1 IDF_SDK_PATH=$HOME/WebstormProjects/idf-sdk concurrently -n server,vite \"npm run server\" \"vite --host 0.0.0.0\"",
    "demo:init": "node scripts/demo-env.mjs --fresh --out ./.demo",
    "demo:start": "npm run demo:init && concurrently -n server,vite,calendar \"npm run server\" \"npm run dev\" \"npm run calendar\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/plots": "^2.6.8",
    "@anthropic-ai/sdk": "^0.88.0",
    "@codemirror/lang-json": "^6.0.2",
    "@intent-driven/adapter-antd": "^1.9.0",
    "@intent-driven/adapter-antd-blockeditor-tiptap": "^0.3.1",
    "@intent-driven/adapter-apple": "^1.4.2",
    "@intent-driven/adapter-mantine": "^1.4.2",
    "@intent-driven/adapter-shadcn": "^1.4.2",
    "@intent-driven/canvas-kit": "^0.2.0",
    "@intent-driven/core": "^0.114.0",
    "@intent-driven/effect-sink": "^0.2.1",
    "@intent-driven/engine": "^0.3.0",
    "@intent-driven/importer-openapi": "^0.16.0",
    "@intent-driven/llm-bridge": "^0.4.1",
    "@intent-driven/llm-subprocess": "^0.2.1",
    "@intent-driven/renderer": "^0.66.0",
    "@mantine/core": "^9.0.1",
    "@mantine/dates": "^9.0.1",
    "@mantine/hooks": "^9.0.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@uiw/react-codemirror": "^4.25.9",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "antd": "^6.3.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "express": "^5.2.1",
    "framer-motion": "^11.18.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "multer": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.5",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recast": "^0.23.11",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.170.0",
    "uuid": "^13.0.0",
    "vite": "^8.0.8",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "concurrently": "^9.2.1",
    "jsdom": "^25.0.1",
    "supertest": "^7.2.2",
    "swagger2openapi": "^7.0.8",
    "typescript": "^5.5.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  },
  "private": true
}
