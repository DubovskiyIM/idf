; Держим lockfile стабильным между локальной разработкой (macOS) и CI (linux).
; Без этого optional transitive-deps (3d-force-graph, @emnapi/*) выкидываются
; при `npm install` на одной платформе и ломают `npm ci` на другой.
include=optional

; @mantine/core декларирует peer react-dom@^19.2.0; @intent-driven/* пакеты
; — react-dom>=18 без явной 19.x. Strict peer-resolve npm@10+ падает на
; @types/react-dom missing при npm ci. legacy-peer-deps согласует resolution
; между локальным `npm install` и CI `npm ci`.
legacy-peer-deps=true
